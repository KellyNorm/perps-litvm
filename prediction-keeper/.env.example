# Prediction-keeper config. Copy to prediction-keeper/.env (gitignored) and fill in.
#
# THIS IS A SEPARATE SERVICE from the perp keeper (keeper/). It runs its OWN
# dedicated account, its OWN Railway service, and shares NOTHING with keeper.mjs.
# A crash / gas-exhaustion / nonce-stall here must never affect the perp keeper.
#
# NOTE: unlike the perp keeper, this keeper earns NO fee — replenish/observe/settle
# carry no bounty. It is a NET zkLTC SPENDER. Keep its account funded.

# LitVM LiteForge testnet (chain 4441).
LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/infra-partner-http

# Dedicated prediction-keeper key — its OWN account, funded with zkLTC for gas.
# Do NOT reuse KEEPER_PRIVATE_KEY (perp keeper) or DEPLOYER_PRIVATE_KEY.
# Generate with:  cast wallet new
# then paste the private key here and fund the printed address with zkLTC.
PREDICTION_KEEPER_PRIVATE_KEY=0xYOUR_DEDICATED_PREDICTION_KEEPER_PRIVATE_KEY

# PredictionMarketFactory (chain 4441).
PREDICTION_FACTORY_ADDRESS=0x6338985C7f689C3e1959bfe1a8bb36E44849EA40

# ---- Optional tuning (sane defaults baked in) ----

# Main-loop period in ms (default 10000). Sized around MIN_OBS_SPACING (10s).
# PREDICTION_LOOP_MS=10000

# Full reconcile walk period in ms (default 120000): re-scan marketCount() to catch
# any live market the incremental tracker might have missed.
# PREDICTION_RECONCILE_MS=120000

# Explicit gas limits (NEVER estimated — see README "gas gotcha"). Defaults shown.
# PREDICTION_GAS_REPLENISH=20000000
# PREDICTION_GAS_OBSERVE=500000
# PREDICTION_GAS_SETTLE=3000000

# Explicit gas price in gwei (avoids getFeeData 502/504). Default 0.02 gwei.
# A single getGasPrice() is attempted at startup; this is the fallback/override.
# PREDICTION_GAS_PRICE_GWEI=0.02

# Low-balance warning threshold in zkLTC (default 0.002). Logs a WARN below this.
# PREDICTION_MIN_BALANCE=0.002
