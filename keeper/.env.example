# Keeper service config. Copy to keeper/.env (gitignored) and fill in.
# The keeper runs its OWN dedicated account — NOT the deployer. Fund it with a
# little zkLTC for gas; it earns the 0.5 mUSD execution fee on every fill.

# LitVM LiteForge testnet (chain 4441).
LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/infra-partner-http

# Dedicated keeper key — its own account, funded with zkLTC for gas. Do NOT
# reuse the deployer/trader key. earns the per-fill fee.
KEEPER_PRIVATE_KEY=0xYOUR_DEDICATED_KEEPER_PRIVATE_KEY

# Deployed contract addresses (chain 4441).
POSITION_MANAGER_ADDRESS=0x9396d36f713302ff39e0ba5b38012656f8e4eacf
# mUSD collateral token — read-only here, used only to report fees earned.
MUSD_ADDRESS=0x4aedab95d41a31f891ee12d13cd77102705e2def

# RedStone pull-oracle data service.
REDSTONE_DATA_SERVICE=redstone-primary-prod

# Optional. The keeper backfills the active set by walking the id counter and
# reconciling against requests(id).active (restart-idempotent), so START_BLOCK is
# only a hint for where live log listeners attach. Leave unset to attach at head.
# START_BLOCK=

# Optional. Main-loop period in ms (default 2500).
# KEEPER_LOOP_MS=2500
