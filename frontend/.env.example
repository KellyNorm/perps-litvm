# TachyonFi frontend config — copy to `.env` and fill in.
# Only VITE_-prefixed vars are exposed to the browser (Vite rule). NEVER put a
# private key here — the frontend signs nothing it doesn't get from the wallet.

# LitVM LiteForge testnet RPC (chain 4441).
VITE_RPC_URL=https://liteforge.rpc.caldera.xyz/infra-partner-http
VITE_CHAIN_ID=4441

# Deployed contract addresses (chain 4441). Match the root .env / latest deploy.
VITE_MUSD_ADDRESS=0x4aedab95d41a31f891ee12d13cd77102705e2def
VITE_LIQUIDITY_POOL_ADDRESS=0x4716a0c9c504f83918002a3086590f1ed192560b
VITE_POSITION_MANAGER_ADDRESS=0x9396d36f713302ff39e0ba5b38012656f8e4eacf

# RedStone pull-oracle data service (same as scripts/smoke-perps.mjs).
VITE_REDSTONE_DATA_SERVICE=redstone-primary-prod
